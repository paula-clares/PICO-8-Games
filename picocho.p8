-- waves and enemies
etypes={"green","red"}
etfuncs={}
etfuncs["red"]={	--red
			hp=1,
			spr=128,
			sx=0,
			sy=2,
			anim={128,129,130,131,
				132,133},
			score=10,
}
etfuncs["green"]={	--green
		hp=1,
		spr=32,
		sx=1,
		sy=1,
		anim={32,33,34,35},
		score=5
}

function spawnwave()
	spawnenemies(1)
end

function nextwave()
	wave+=1
	mode="waveintro"
	wavetime=80
	if wave==1 or wave%5==1 then
		sfx(26)	
	else
		sfx(22)
	end
end

function spawnenemies(total)
	for i=1,total do
		local etype=enemytypes[
				flr(rnd(2)+1)
			]
		enemy={
			x=rnd(100)+10,
			y=-8-(rnd(230)),
			type=etype,
			sprw=1,
			sprh=1,
			animi=1,
			flash=0,
			flashing=function(self)
				self.flash-=1
				if self.type=="green" then
					pal(11,7)
				elseif self.type=="red" then
					pal(8,7)
				end
			end
		}
		--[[
		enemy.hp=etfuncs[etype].hp
		enemy.spr=etfuncs[etype].spr
		enemy.sx=etfuncs[etype].sx
		enemy.sy=etfuncs[etype].sy
		enemy.anim=etfuncs[etype]
			.anim
		enemy.score=etfuncs[etype]
			.score		
		]]--
		--[[ this fucks up the perfm?
		no, it was because i had too
		many print()'s
		]]--
		--add properties that depend
		--on enemy type
		for k,v in 
			pairs(etfuncs[etype]) do
		 enemy[k]=v
		end
		
		add(enemies,enemy)
	end
end
-->8
--store screen that shows every
--5 waves
function init_store()
	cls(2)
	mode="store"
	items={}
	option=4
	options={
		{act="item",spr=25,x=20,y=30,
			cost=10,desc="dash"},
		{act="item",spr=25,x=55,y=30,
			cost=10,desc="dash"},
		{act="item",spr=25,x=90,y=30,
			cost=10,desc="dash"},
		{act="continue",x=90,y=120,
		w=1,h=1}
	}
end

function exit_store()
	mode="game"
	storeintrotime=45
	nextwave()
end

function drawoptions()
	for k,v in pairs(options) do
		if v.act=="item" then
			spr(25, v.x, v.y, 2, 2)
			if k==option then
				spr(23, v.x-8, v.y, 1, 2,
					true)
				spr(23, v.x+16, v.y, 1, 2)
				print(v.cost,v.x+4,v.y+17)
				print(v.desc,v.x-8,v.y+30)
			end
		end
		if v.act=="continue" then
			if k==option then
				print(
				"[continue]",85,120,blink())	
			else
				print("continue",90,120,7)
			end
		end
	end		
end

function selectoption()
local selopt=options[option]
	if selopt.act=="continue" then
		exit_store()
	elseif selopt.act=="item" then
		--buy item (or try)
		if score>=selopt.cost then
			score-=selopt.cost
			del(options,selopt)
			option=#options
		else	
		end 
	end
end
