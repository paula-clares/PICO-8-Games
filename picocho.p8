--this will clear the screen
spr(0,70,70)

--init is called once
--at the beginning
function _init()
	cls(1)
	--mode
	blinkt=0
	startspr=32
	startscreen()
	storeintrotime=45
	
		--stars
	stars={}
	for i=1,57 do
		local newstar={
			x=flr(rnd(128)),
			y=flr(rnd(128)),
			spd=rnd(1.5)+0.5
		}
		add(stars,newstar)
	end
end --_init

--draw gets called when a new
--frame gets drawn to the scene
--(30fps)
function _draw()
	if mode=="game" then
		draw_game()
	elseif mode=="start" then
		draw_start()
	elseif mode=="waveintro" then
		draw_waveintro()
	elseif mode=="store" then
		draw_store()
	elseif mode=="storeintro" then
		draw_storeintro()
	elseif mode=="over" then
		draw_over()
	elseif mode=="win" then
		draw_win()
	end
end --draw

function _update()
	blinkt+=1
	
	if mode=="game" then
		update_game()
	elseif mode=="start" then
		update_start()
	elseif mode=="waveintro" then
		update_waveintro()
	elseif mode=="store" then
		update_store()
	elseif mode=="storeintro" then
		update_storeintro()
	elseif mode=="over" then
		update_over()
	elseif mode=="win" then
		update_win()
	end
end --update

function startscreen()
	mode="start"
	music(1)
end

function start_game()
	music(-1,500)
	sfx(26)	
	wave=4
	nextwave()
	
	ship={
		x=64,
		y=90,
		sx=2,
		sy=2,
		sprw=1,
		sprh=1,	
		invul=0,
		bultimer=8
	}

	--sprites
	shipspr=0
	flamespr=9
	bulspr=16
	genemy=32
	renemy=128
	
	muzzle=0
	
	--ui
	score=0
	lives=3
	
	--bullets
	bullets={}
	--enemies
	enemytypes={"green","red"}
	enemies={}
	spawnenemies(1)
	--explosions
	explos={}
	--particles
	parts={}
	--shock waves
	shwaves={}
	
end --start_game
-->8
--tools

function starfield()
	for i=1,#stars do
		local scol=7
		local mystar=stars[i]
		
		if mystar.spd<1 then
			scol=13
		elseif mystar.spd<1.5 then
			scol=15
		end
		
		pset(mystar.x,mystar.y,scol)
	end	
end

function animatestars()
	for i=1,#stars do
		local mystar=stars[i]
		
		mystar.y=mystar.y+mystar.spd
		
		if mystar.y>128 then
			mystar.y=mystar.y-128
		end
		--no need to replace in array
	end
end

function blink()
	local blinkanim={5,5,5,6,6,6,
	7,7,7,6,6,6}
	
	if blinkt>#blinkanim then
		blinkt=1
	end
	return blinkanim[blinkt]
end

function svisible()
	if ship.invul<=0 do
		return true
	end
	
	return ship.invul%5!=0
end

function shoot()
	if ship.bultimer<=0 then
		local newbul={
			x=ship.x,
			y=ship.y-3,
			spr=16,
			sprw=1,
			sprh=1
		}
		add(bullets,newbul)
		sfx(0)
		muzzle=5
		ship.bultimer=8
	end
end

function drawmyspr(myspr)
	spr(myspr.spr,myspr.x,myspr.y,
		myspr.sprw,myspr.sprh)
end

function coll(a,b)
	--right & bottom edges are
	--coords + length-1 because
	--sprites start at 0, so 
	--[0,1,2,3,4,5,6,7] are
	--8 numbers
	local aleft=a.x
	local atop=a.y
	local aright=a.x+7
	local abottom=a.y+7
	
	local bleft=b.x
	local btop=b.y
	local bright=b.x+7
	local bbottom=b.y+7
	
	if atop>bbottom 
		or aleft>bright
		or abottom<btop
		or aright<bleft do
		return false
	end
	
	return true
end

function explode(
	expx,expy,isblue)
	--initial explosion
	local mypa={
			x=expx,
			y=expy,
			sx=0,
			sy=0,
			age=0,
			size=9,
			maxage=3,
			blue=isblue
		}
		add(parts,mypa)
	--the boombooms
	for i=1,25 do
		local mypa={
			x=expx,
			y=expy,
			sx=(rnd()-.5)*6,
			sy=(rnd()-.5)*6,
			age=rnd(2),
			size=rnd(3)+1,
			maxage=10+rnd(10),
			blue=isblue
		}
		add(parts,mypa)
	end
	
	--sparks
	for i=1,20 do
		local mypa={
			x=expx,
			y=expy,
			sx=(rnd()-.5)*11,
			sy=(rnd()-.5)*11,
			age=rnd(2),
			size=rnd(4)+1,
			maxage=10+rnd(10),
			blue=isblue,
			spark=true
		}
		add(parts,mypa)
	end
	lshwave(expx,expy)
end

function cbyagered(age)
	local pacol=7
	if age>15 then
		pacol=5
	elseif age>12 then
		pacol=2
	elseif age>10 then
		pacol=8
	elseif age>7 then
		pacol=9
	elseif age>5 then
		pacol=10
	end
	
	return pacol
end

function cbyageblue(age)
	local pacol=7
	if age>15 then
		pacol=1
	elseif age>12 then
		pacol=1
	elseif age>10 then
		pacol=13
	elseif age>7 then
		pacol=12
	elseif age>5 then
		pacol=6
	end
	
	return pacol
end

function sshwave(swx,swy)
	local mysw={
		x=swx,
		y=swy,
		rad=1,
		finrad=7,
		col=9,
		spd=.5
	}
	add(shwaves,mysw)
end

function lshwave(swx,swy)
	local mysw={
		x=swx,
		y=swy,
		rad=0,
		finrad=20,
		col=7,
		spd=3.5
	}
	add(shwaves,mysw)
end

function ssparks(sx,sy)
	for i=1,2 do
		local mypa={
			x=sx,
			y=sy,
			sx=(rnd()-.5)*8,
			sy=(rnd()-1)*3,
			age=rnd(2),
			size=rnd(4)+1,
			maxage=10+rnd(10),
			blue=isblue,
			spark=true
		}
		add(parts,mypa)
	end
end

function btnreleased()
	if not btn(❎) 
		and not btn(🅾️) then
		btnrelea=true
	end
end
-->8
--update
function update_game()
	animatestars()
	--controls
	ship.sx=0
	ship.sy=0
	ship.spr=0
	
	if btn(⬅️) then
		ship.sx=-2
		ship.spr=1
	end
	
	if btn(➡️) then
		ship.sx=2
		ship.spr=2
	end
	
	if btn(⬆️) then
		ship.sy=-2
	end

	if btn(⬇️) then
		ship.sy=2
	end
	
	if btn(❎) then
		shoot()
	end
	
	if btn(🅾️) then
		
	end
		
	--update ship
	ship.x+=ship.sx
	ship.y+=ship.sy
	ship.invul-=1
	ship.bultimer-=1
	
	--checking bounds
	if ship.x>120 then
		ship.x=120
	end
	if ship.x<0 then
		ship.x=0
	end
	if ship.y<0 then
		ship.y=0
	elseif ship.y>119 then
		ship.y=119
	end
	
	--update bullets
	--read array backwards to avoid
	--problems with local var
	for i=#bullets,1,-1 do
		local mybul=bullets[i]
		mybul.y-=3
		mybul.spr+=1	
		
		if mybul.spr>19 then
			mybul.spr=16
		end
		if mybul.y<-9 then
			del(bullets,mybul)
		end	
	end
	
	--update enemies
	for myenemy in all(enemies) do
		myenemy.y+=myenemy.sy
		myenemy.x+=myenemy.sx
		myenemy.animi+=.25
		if flr(myenemy.animi)>
			#myenemy.anim then
			myenemy.animi=1		
		end	
		myenemy.spr=
			myenemy.
				anim[flr(myenemy.animi)]
		
		--enemy leaves screen
		if myenemy.y>128 then
		 del(enemies,myenemy)
		 spawnenemies(1)
		end
		if myenemy.x>123 then
			myenemy.x=123
			myenemy.sx=myenemy.sx*-1
		elseif myenemy.x<0 then
			myenemy.x=0
			myenemy.sx=myenemy.sx*-1
		end
	end
	
	--check collision ship x enemy
	for myenemy in all(enemies) do
		if ship.invul<=0
			and coll(myenemy,ship) then
			explode(
				ship.x+4,ship.y+4,true)
			lives-=1
			sfx(3)
			ship.invul=45
		end
		--check collision
		--bullet x enemy
		for bullet in all(bullets) do
			if coll(myenemy,bullet) then
				del(bullets,bullet)
				sshwave(
					bullet.x+4,bullet.y+4)
				ssparks(
					myenemy.x+4,myenemy.y+4)
				sfx(4)
				myenemy.hp-=1
				myenemy.flash=4
				if myenemy.hp<=0 then
					del(enemies,myenemy)
					sfx(6)
					score+=myenemy.score
					--spawnenemies(1)
					explode(myenemy.x+4,
						myenemy.y+4,false)
						
					if #enemies==0 then
						if wave%5==0 then
							--if wave 5 if finished,
							--enter store
							--init_store()
							mode="storeintro"
						else
							nextwave()
						end
					end
				end
			end
		end
	end
		
	--check game over
	if lives<=0 then
		sfx(23)
		mode="over"
		return
	end
	
	--update flame
	flamespr+=1
	if flamespr>14 then
		flamespr=9
	end	
	
	--update muzzle
	if muzzle>0 then
		muzzle=muzzle-1
	end
	
end--update-game

function update_start()
	animatestars()
	startspr+=.1
	if startspr>35 then
		startspr=32
	end
	
	btnreleased()
	if btnrelea then
		if btnp(❎) or btnp(🅾️) then
			start_game()
			btnrelea=false
		end
	end
end

function update_over()
	btnreleased()
	if btnrelea then
		if btnp(❎) or btnp(🅾️) then
			startscreen()
			btnrelea=false
		end
	end
end

function update_waveintro()
	update_game()
	wavetime-=1
	if wavetime<0 then
		mode="game"
		spawnwave()
	end
end

function update_win()
	btnreleased()
	if btnrelea then
		if btnp(❎) or btnp(🅾️) then
			startscreen()
			btnrelea=false
		end
	end
end

function update_store()
	btnreleased()
	if btnp(⬅️) or btnp(⬆️) then
		option-=1
	end
	
	if btnp(➡️) or btnp(⬇️) then
		option+=1
	end
	
	if btnrelea and btnp(❎) then
		selectoption()
	end
	
	if btnp(🅾️) then
		option=#options
	end 
	
	if option<1 then
		option=1
	elseif option>#options then
		option=#options
	end
end

function update_storeintro()
	update_game()
	storeintrotime-=1
	if storeintrotime<0 then
		init_store()
	end
end
-->8
--draw

--draw gets called when a new
--frame gets drawn to the scene
--(30fps)
function draw_game()
	cls(0)
	starfield()
	if svisible() do
		drawmyspr(ship)
		spr(flamespr,ship.x,ship.y+5)
	end
	
	--bullets
	for mybul in all(bullets) do
		drawmyspr(mybul)
	end
	
	--enemies
	for myenemy in all(enemies) do
		if myenemy.flash>0 then
			myenemy:flashing()
		end
		drawmyspr(myenemy)
		pal()
	end

	--muzzle
	if muzzle>0 then
		circfill(ship.x+3,ship.y-1
		,muzzle,7)
		circfill(ship.x+4,ship.y-1
		,muzzle,7)
	end
	
	--shock waves
	for mysw in all(shwaves) do
		circ(
			mysw.x,mysw.y,mysw.rad,
			mysw.col)
		mysw.rad+=mysw.spd
		if mysw.rad>mysw.finrad then
			del(shwaves,mysw)
		end
	end
	
	--particles
	for mypa in all(parts) do
		local pacol=7
		if mypa.blue then
			pacol=cbyageblue(
			mypa.age)
		else
			pacol=cbyagered(
			mypa.age)
		end
		
		if mypa.spark then
			pset(
				mypa.x,mypa.y,7
			)
		else
			circfill(
				mypa.x,mypa.y,mypa.size,
				pacol
			)
		end
		
		
		mypa.x+=mypa.sx
		mypa.y+=mypa.sy
		mypa.sx=mypa.sx*.85
		mypa.sy=mypa.sy*.85
		mypa.age+=1
		
		if mypa.age>mypa.maxage then
			mypa.size-=.5
			if mypa.size<0 then
				del(parts,mypa)
			end
		end
	end
	
	--ui should be last thing to
	--draw so its on top
	print("score:"..score,30,1,12)
	
	for i=0,2 do
		if lives>=i+1 then
			spr(48,1+i*9,1)	
		else
			spr(49,1+i*9,1)
		end
	end
	
end--draw_game

function draw_start()
	cls(0)
	starfield()
	print("my awesome gueim",
	30,40,12)
	print("press any key to start",
	25,70,blink())
	spr(startspr,64,58)
	--draw sprite range starting at
	--65, 4 wide, 3 high
	--at (80,80)
	spr(65, 80, 80, 4, 3)
end

function draw_over()
	draw_game()
	print("gueim ovaaa",
	40,40,2)
	print("press any key to start",
	25,70,blink())
end

function draw_waveintro()
	draw_game()
	print(
		"wave "..wave,57,60,blink())
end

function draw_win()
	draw_game()
	print("condragulations",
	50,60,11)
	print(
	"press any key to continue",
	25,70,blink())
end

function draw_store()
	cls(2)
	print("score:"..score,1,1,12)
	drawoptions()
end

function draw_storeintro()
	draw_game()
	print(
		"cool! entering store..."
		,20,60,blink())
end
